{
  "name": "eshop-pdv",
  "version": "1.0.0",
  "description": "Sistema de PDV e Gestão de Estoque - Arquitetura modular para varejo",
  "main": "dist/main/main.js",
  "author": "E-Shop Team",
  "homepage": "https://github.com/eshop-pdv/eshop-pdv",
  "scripts": {
    "start": "concurrently -n main,renderer \"tsc && electron .\" \"vite\"",
    "dev": "concurrently -n main,renderer \"tsc && wait-on dist/main/main.js && NODE_ENV=development electron .\" \"vite\"",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:build": "electron-builder",
    "reset-admin": "node scripts/reset-admin.js"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0"
  },
  "build": {
    "appId": "com.eshop.pdv",
    "productName": "E-Shop PDV",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bcryptjs/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office"
    },
    "win": {
      "target": "nsis"
    }
  }
}
